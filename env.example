# Copie este arquivo para ".env" e preencha com os dados do seu app no Bling.

# Credenciais do app criado no Bling (Central de extensões > Área do integrador)
BLING_CLIENT_ID=coloque_seu_client_id_aqui
BLING_CLIENT_SECRET=coloque_seu_client_secret_aqui

# URL pública do seu backend + /callback  (tem que ser EXATAMENTE igual à
# "URL de redirecionamento" cadastrada no app do Bling)
# Em teste local:  http://localhost:3000/callback
# Em nuvem:        https://SEU-APP.up.railway.app/callback
BLING_REDIRECT_URI=http://localhost:3000/callback

# Porta do servidor
PORT=3000
